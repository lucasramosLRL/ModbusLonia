<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Modbus.Desktop.ViewModels"
             xmlns:svc="using:Modbus.Desktop.Services"
             x:Class="Modbus.Desktop.Views.SettingsView"
             x:DataType="vm:SettingsViewModel">

    <StackPanel Margin="{StaticResource MarginView}" Spacing="24">

        <TextBlock Text="{Binding [SettingsTitle], Source={x:Static svc:LocalizationService.Instance}}"
                   Classes="main-title" />

        <!-- Language selection -->
        <Border Classes="card"
                Width="320"
                HorizontalAlignment="Left">
            <StackPanel Spacing="10">
                <TextBlock Text="{Binding [Language], Source={x:Static svc:LocalizationService.Instance}}"
                           Classes="section-title" />
                <ComboBox ItemsSource="{Binding AvailableLanguages}"
                          SelectedItem="{Binding SelectedLanguage}"
                          HorizontalAlignment="Stretch">
                    <ComboBox.ItemTemplate>
                        <DataTemplate DataType="{x:Type svc:AppLanguage}">
                            <TextBlock Text="{Binding Converter={x:Static svc:AppLanguageConverter.Instance}}" />
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
            </StackPanel>
        </Border>

        <!-- COM port settings -->
        <Border Classes="card" HorizontalAlignment="Left">
            <StackPanel Spacing="12">
                <TextBlock Text="{Binding [SerialPortSettings], Source={x:Static svc:LocalizationService.Instance}}"
                           Classes="section-title" />
                <Grid ColumnDefinitions="160,160,130,130,130" RowDefinitions="Auto,Auto">

                    <!-- Row 0: labels -->
                    <TextBlock Grid.Row="0" Grid.Column="0"
                               Text="{Binding [ComPort], Source={x:Static svc:LocalizationService.Instance}}"
                               Classes="label-small" />
                    <TextBlock Grid.Row="0" Grid.Column="1"
                               Text="{Binding [BaudRate], Source={x:Static svc:LocalizationService.Instance}}"
                               Classes="label-small" Margin="12,0,0,0" />
                    <TextBlock Grid.Row="0" Grid.Column="2"
                               Text="{Binding [DataBits], Source={x:Static svc:LocalizationService.Instance}}"
                               Classes="label-small" Margin="12,0,0,0" />
                    <TextBlock Grid.Row="0" Grid.Column="3"
                               Text="{Binding [Parity], Source={x:Static svc:LocalizationService.Instance}}"
                               Classes="label-small" Margin="12,0,0,0" />
                    <TextBlock Grid.Row="0" Grid.Column="4"
                               Text="{Binding [StopBits], Source={x:Static svc:LocalizationService.Instance}}"
                               Classes="label-small" Margin="12,0,0,0" />

                    <!-- Row 1: controls -->
                    <Grid Grid.Row="1" Grid.Column="0" ColumnDefinitions="*,Auto" Margin="0,4,0,0">
                        <ComboBox Grid.Column="0"
                                  ItemsSource="{Binding AvailablePorts}"
                                  SelectedItem="{Binding SelectedPort}"
                                  HorizontalAlignment="Stretch" />
                        <Button Grid.Column="1"
                                Content="↺"
                                Command="{Binding RefreshPortsCommand}"
                                Padding="8,4"
                                Margin="4,0,0,0"
                                ToolTip.Tip="{Binding [RefreshPortList], Source={x:Static svc:LocalizationService.Instance}}"
                                VerticalAlignment="Center" />
                    </Grid>
                    <ComboBox Grid.Row="1" Grid.Column="1"
                              ItemsSource="{Binding AvailableBaudRates}"
                              SelectedItem="{Binding BaudRate}"
                              HorizontalAlignment="Stretch"
                              Margin="12,4,0,0" />
                    <NumericUpDown Grid.Row="1" Grid.Column="2"
                                   Value="{Binding DataBits}"
                                   Minimum="7" Maximum="8" Increment="1"
                                   FormatString="0"
                                   HorizontalAlignment="Stretch"
                                   Margin="12,4,0,0" />
                    <ComboBox Grid.Row="1" Grid.Column="3"
                              ItemsSource="{Binding AvailableParities}"
                              SelectedItem="{Binding SelectedParity}"
                              HorizontalAlignment="Stretch"
                              Margin="12,4,0,0" />
                    <ComboBox Grid.Row="1" Grid.Column="4"
                              ItemsSource="{Binding AvailableStopBits}"
                              SelectedItem="{Binding SelectedStopBits}"
                              HorizontalAlignment="Stretch"
                              Margin="12,4,0,0" />
                </Grid>
                <TextBlock Text="{Binding [PortUnavailable], Source={x:Static svc:LocalizationService.Instance}}"
                           FontSize="{StaticResource FontSizeMeta}"
                           Foreground="{StaticResource BrushWarningOrange}"
                           IsVisible="{Binding IsPortUnavailable}"
                           Margin="0,6,0,0" />
            </StackPanel>
        </Border>

    </StackPanel>
</UserControl>
