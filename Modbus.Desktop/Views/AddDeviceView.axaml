<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Modbus.Desktop.ViewModels"
             xmlns:svc="using:Modbus.Desktop.Services"
             x:Class="Modbus.Desktop.Views.AddDeviceView"
             x:DataType="vm:AddDeviceViewModel">

    <DockPanel Margin="28,20">

        <!-- Header -->
        <Grid DockPanel.Dock="Top" ColumnDefinitions="Auto,*" Margin="0,0,0,20">
            <Button Content="{Binding [Back], Source={x:Static svc:LocalizationService.Instance}}"
                    Command="{Binding GoBackCommand}"
                    Padding="12,8"
                    VerticalAlignment="Center" />
            <TextBlock Grid.Column="1"
                       Text="{Binding [AddDeviceTitle], Source={x:Static svc:LocalizationService.Instance}}"
                       FontSize="24"
                       FontWeight="SemiBold"
                       Margin="20,0"
                       VerticalAlignment="Center" />
        </Grid>

        <!-- Saving progress bar -->
        <ProgressBar DockPanel.Dock="Top"
                     IsIndeterminate="True"
                     IsVisible="{Binding IsSaving}"
                     Height="3"
                     Margin="0,0,0,4" />

        <!-- Main scrollable content -->
        <ScrollViewer>
            <StackPanel Spacing="16">

                <!-- Transport selection -->
                <Border Padding="16"
                        CornerRadius="8"
                        BorderThickness="1"
                        BorderBrush="#1A1A2E"
                        Background="#1A1A2E">
                    <StackPanel Spacing="8">
                        <TextBlock Text="{Binding [TransportType], Source={x:Static svc:LocalizationService.Instance}}"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   Foreground="#FFFFFF" />
                        <StackPanel Orientation="Horizontal" Spacing="24">
                            <RadioButton Content="{Binding [RtuOption], Source={x:Static svc:LocalizationService.Instance}}"
                                         IsChecked="{Binding IsRtu, Mode=TwoWay}"
                                         GroupName="Transport" />
                            <RadioButton Content="{Binding [TcpOption], Source={x:Static svc:LocalizationService.Instance}}"
                                         IsChecked="{Binding IsTcp, Mode=TwoWay}"
                                         GroupName="Transport" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- RTU: current COM port summary + address range -->
                <Border IsVisible="{Binding IsRtu}"
                        Padding="16"
                        CornerRadius="8"
                        BorderThickness="1"
                        BorderBrush="#1A1A2E"
                        Background="#1A1A2E">
                    <StackPanel Spacing="12">

                        <!-- COM port summary row -->
                        <Grid ColumnDefinitions="*,Auto">
                            <StackPanel Grid.Column="0" Spacing="4" VerticalAlignment="Center">
                                <TextBlock Text="{Binding [SerialPortSettings], Source={x:Static svc:LocalizationService.Instance}}"
                                           FontSize="11" Opacity="0.55" Foreground="#FFFFFF" />
                                <!-- Summary from RtuSettingsService (e.g. "COM5  9600  8N2") -->
                                <TextBlock FontSize="15"
                                           FontWeight="SemiBold"
                                           Foreground="#FFFFFF">
                                    <TextBlock.Text>
                                        <MultiBinding StringFormat="{}{0}">
                                            <Binding Path="Summary" Source="{x:Static svc:RtuSettingsService.Instance}" />
                                        </MultiBinding>
                                    </TextBlock.Text>
                                </TextBlock>
                                <TextBlock Text="{Binding [NoPortConfigured], Source={x:Static svc:LocalizationService.Instance}}"
                                           FontSize="13"
                                           Foreground="#E57373"
                                           IsVisible="{Binding Summary, Source={x:Static svc:RtuSettingsService.Instance}, Converter={x:Static StringConverters.IsNullOrEmpty}}" />
                                <TextBlock Text="{Binding [PortUnavailable], Source={x:Static svc:LocalizationService.Instance}}"
                                           FontSize="13"
                                           Foreground="#FFB300"
                                           IsVisible="{Binding IsRtuPortUnavailable}" />
                            </StackPanel>
                            <Button Grid.Column="1"
                                    Content="{Binding [ChangeInSettings], Source={x:Static svc:LocalizationService.Instance}}"
                                    Command="{Binding GoToSettingsCommand}"
                                    Padding="12,8"
                                    VerticalAlignment="Center" />
                        </Grid>

                        <!-- Address range -->
                        <StackPanel Spacing="4">
                            <TextBlock Text="{Binding [AddressRange], Source={x:Static svc:LocalizationService.Instance}}"
                                       FontSize="11" Opacity="0.55" Foreground="#FFFFFF" />
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <NumericUpDown Value="{Binding StartAddress}"
                                               Minimum="1" Maximum="247" Increment="1"
                                               FormatString="0"
                                               Width="112" />
                                <TextBlock Text="—" VerticalAlignment="Center" Opacity="0.55" />
                                <NumericUpDown Value="{Binding EndAddress}"
                                               Minimum="1" Maximum="247" Increment="1"
                                               FormatString="0"
                                               Width="112" />
                            </StackPanel>
                        </StackPanel>

                    </StackPanel>
                </Border>

                <!-- TCP connection settings -->
                <Border IsVisible="{Binding IsTcp}"
                        Padding="16"
                        CornerRadius="8"
                        BorderThickness="1"
                        BorderBrush="#1A1A2E"
                        Background="#1A1A2E">
                    <StackPanel Spacing="12">
                        <TextBlock Text="{Binding [NetworkSettings], Source={x:Static svc:LocalizationService.Instance}}"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   Foreground="#FFFFFF" />
                        <TextBlock Text="{Binding [NetworkSettingsHint], Source={x:Static svc:LocalizationService.Instance}}"
                                   FontSize="12"
                                   Opacity="0.6"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <!-- Scan action row -->
                <StackPanel Spacing="8">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button Content="{Binding [SearchNetwork], Source={x:Static svc:LocalizationService.Instance}}"
                                Command="{Binding ScanCommand}"
                                Padding="16,8" />
                        <Button Content="{Binding [Cancel], Source={x:Static svc:LocalizationService.Instance}}"
                                Command="{Binding CancelScanCommand}"
                                Padding="12,8" />
                        <TextBlock Text="{Binding ScanStatus}"
                                   VerticalAlignment="Center"
                                   Opacity="0.65"
                                   Margin="8,0,0,0" />
                    </StackPanel>
                    <ProgressBar Value="{Binding ScanProgress}"
                                 Maximum="{Binding ScanTotal}"
                                 IsVisible="{Binding IsScanning}"
                                 Height="4" />
                </StackPanel>

                <!-- Scan results -->
                <StackPanel Spacing="8">
                    <TextBlock Text="{Binding [FoundDevices], Source={x:Static svc:LocalizationService.Instance}}"
                               FontSize="14"
                               FontWeight="SemiBold" />
                    <TextBlock Text="{Binding [NoFoundDevicesYet], Source={x:Static svc:LocalizationService.Instance}}"
                               IsVisible="{Binding !ScanResults.Count}"
                               Opacity="0.5"
                               FontSize="13" />
                    <ListBox x:Name="ScanResultsList"
                             ItemsSource="{Binding ScanResults}"
                             SelectedItem="{Binding SelectedResult}"
                             IsVisible="{Binding ScanResults.Count}"
                             MaxHeight="220">
                        <ListBox.ItemTemplate>
                            <DataTemplate DataType="{x:Type vm:ScanResultViewModel}">
                                <Grid ColumnDefinitions="*,120,100,100,80" Margin="4,2">
                                    <TextBlock Grid.Column="0"
                                               Text="{Binding DisplayName}"
                                               FontWeight="Medium"
                                               VerticalAlignment="Center" />
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding AddressText}"
                                               FontSize="12"
                                               Opacity="0.65"
                                               VerticalAlignment="Center" />
                                    <TextBlock Grid.Column="2"
                                               Text="{Binding SlaveIdText}"
                                               FontSize="12"
                                               Opacity="0.65"
                                               VerticalAlignment="Center"
                                               IsVisible="{Binding #ScanResultsList.DataContext.IsRtu, FallbackValue=True}" />
                                    <TextBlock Grid.Column="3"
                                               Text="{Binding SerialText}"
                                               FontSize="12"
                                               Opacity="0.65"
                                               VerticalAlignment="Center" />
                                    <TextBlock Grid.Column="4"
                                               Text="{Binding FirmwareText}"
                                               FontSize="12"
                                               Opacity="0.65"
                                               VerticalAlignment="Center" />
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </StackPanel>

                <!-- Device details form -->
                <Border Padding="16"
                        CornerRadius="8"
                        BorderThickness="1"
                        BorderBrush="#1A1A2E"
                        Background="#1A1A2E">
                    <StackPanel Spacing="12">
                        <TextBlock Text="{Binding [DeviceDetails], Source={x:Static svc:LocalizationService.Instance}}"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   Foreground="#FFFFFF" />
                        <Grid ColumnDefinitions="*,200,200" RowDefinitions="Auto">
                            <StackPanel Grid.Column="0" Spacing="4">
                                <TextBlock Text="{Binding [Name], Source={x:Static svc:LocalizationService.Instance}}"
                                           FontSize="11" Opacity="0.55" Foreground="#1F1F1F" />
                                <TextBox Text="{Binding DeviceName}"
                                         Watermark="{Binding [DeviceNameWatermark], Source={x:Static svc:LocalizationService.Instance}}" />
                            </StackPanel>
                            <StackPanel Grid.Column="1" Spacing="4" Margin="12,0,0,0"
                                        IsVisible="{Binding IsRtu}">
                                <TextBlock Text="{Binding [Address], Source={x:Static svc:LocalizationService.Instance}}"
                                           FontSize="11" Opacity="0.55" Foreground="#1F1F1F" />
                                <NumericUpDown Value="{Binding SlaveId}"
                                               Minimum="1" Maximum="247" Increment="1"
                                               FormatString="0"
                                               HorizontalAlignment="Stretch" />
                            </StackPanel>
                            <StackPanel Grid.Column="2" Spacing="4" Margin="12,0,0,0"
                                        IsVisible="{Binding IsTcp}">
                                <TextBlock Text="{Binding [DeviceIp], Source={x:Static svc:LocalizationService.Instance}}"
                                           FontSize="11" Opacity="0.55" Foreground="#1F1F1F" />
                                <TextBox Text="{Binding DeviceIp}"
                                         Watermark="{Binding [DeviceIpWatermark], Source={x:Static svc:LocalizationService.Instance}}" />
                            </StackPanel>
                        </Grid>

                        <!-- Save error -->
                        <TextBlock Text="{Binding SaveError}"
                                   IsVisible="{Binding SaveError, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                   Foreground="#D32F2F"
                                   FontSize="13" />
                    </StackPanel>
                </Border>

                <!-- Save row -->
                <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,0,0,20">
                    <Button Content="{Binding [SaveDevice], Source={x:Static svc:LocalizationService.Instance}}"
                            Command="{Binding SaveCommand}"
                            Padding="20,10"
                            FontWeight="Medium" />
                    <ProgressBar IsIndeterminate="True"
                                 IsVisible="{Binding IsSaving}"
                                 Width="100"
                                 Height="4"
                                 VerticalAlignment="Center" />
                </StackPanel>

            </StackPanel>
        </ScrollViewer>

    </DockPanel>
</UserControl>
