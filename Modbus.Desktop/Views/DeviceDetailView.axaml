<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Modbus.Desktop.ViewModels"
             xmlns:svc="using:Modbus.Desktop.Services"
             x:Class="Modbus.Desktop.Views.DeviceDetailView"
             x:DataType="vm:DeviceDetailViewModel">

    <DockPanel Margin="{StaticResource MarginView}">

        <!-- Header -->
        <Grid DockPanel.Dock="Top" ColumnDefinitions="Auto,*,Auto" Margin="0,0,0,20">
            <Button Content="{Binding [Back], Source={x:Static svc:LocalizationService.Instance}}"
                    Command="{Binding GoBackCommand}"
                    Padding="{StaticResource PaddingButtonSmall}"
                    VerticalAlignment="Center" />
            <StackPanel Grid.Column="1" Margin="20,0" VerticalAlignment="Center">
                <TextBlock Text="{Binding Device.Name}"
                           Classes="page-title" />
                <TextBlock Text="{Binding Device.StatusText}"
                           FontSize="{StaticResource FontSizeSectionTitle}"
                           Opacity="0.65" />
            </StackPanel>
            <Button Grid.Column="2"
                    Content="{Binding [Refresh], Source={x:Static svc:LocalizationService.Instance}}"
                    Command="{Binding RefreshCommand}"
                    Padding="{StaticResource PaddingButton}"
                    VerticalAlignment="Center" />
        </Grid>

        <!-- Loading bar -->
        <ProgressBar DockPanel.Dock="Top"
                     IsIndeterminate="True"
                     IsVisible="{Binding IsLoading}"
                     Height="3"
                     Margin="0,0,0,12" />

        <!-- Device info card -->
        <Border DockPanel.Dock="Top" Classes="card" Margin="0,0,0,16">
            <Grid ColumnDefinitions="*,*,*,*">
                <StackPanel Grid.Column="0" Spacing="4">
                    <TextBlock Text="{Binding [Transport], Source={x:Static svc:LocalizationService.Instance}}"
                               Classes="label-small" />
                    <TextBlock Text="{Binding Device.TransportType}" FontWeight="Medium" Foreground="{StaticResource BrushTextPrimary}" />
                </StackPanel>
                <StackPanel Grid.Column="1" Spacing="4">
                    <TextBlock Text="{Binding [Connection], Source={x:Static svc:LocalizationService.Instance}}"
                               Classes="label-small" />
                    <TextBlock Text="{Binding Device.ConnectionAddress}" FontWeight="Medium" Foreground="{StaticResource BrushTextPrimary}" />
                </StackPanel>
                <StackPanel Grid.Column="2" Spacing="4">
                    <TextBlock Text="{Binding [SlaveAddress], Source={x:Static svc:LocalizationService.Instance}}"
                               Classes="label-small" />
                    <TextBlock Text="{Binding Device.SlaveId}" FontWeight="Medium" Foreground="{StaticResource BrushTextPrimary}" />
                </StackPanel>
                <StackPanel Grid.Column="3" Spacing="4">
                    <TextBlock Text="{Binding [Model], Source={x:Static svc:LocalizationService.Instance}}"
                               Classes="label-small" />
                    <TextBlock Text="{Binding Device.ModelDisplayName}" FontWeight="Medium" Foreground="{StaticResource BrushTextPrimary}" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- Tab Control -->
        <TabControl SelectedIndex="{Binding SelectedTabIndex}">

            <!-- Tab 1: Instantaneous Readings -->
            <TabItem>
                <TabItem.Header>
                    <TextBlock Text="{Binding [TabInstantaneous], Source={x:Static svc:LocalizationService.Instance}}" />
                </TabItem.Header>

                <ScrollViewer Padding="0,12,0,0">
                    <StackPanel Spacing="12">

                        <!-- Empty state -->
                        <TextBlock Text="{Binding [NoLiveData], Source={x:Static svc:LocalizationService.Instance}}"
                                   IsVisible="{Binding !ReadingGroups.Count}"
                                   Opacity="0.5"
                                   Margin="0,12" />

                        <!-- Reading groups -->
                        <ItemsControl ItemsSource="{Binding ReadingGroups}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:ReadingGroupViewModel">
                                    <Border Classes="reading-group" Margin="0,0,0,4">
                                        <StackPanel Spacing="12">

                                            <!-- Group header -->
                                            <TextBlock Text="{Binding GroupName}"
                                                       FontSize="{StaticResource FontSizeGroupHeader}"
                                                       FontWeight="SemiBold"
                                                       Foreground="{StaticResource BrushTextPrimary}"
                                                       Opacity="0.85" />

                                            <!-- Readings grid -->
                                            <ItemsControl ItemsSource="{Binding Readings}">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <WrapPanel Orientation="Horizontal" />
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate x:DataType="vm:ElectricalReadingViewModel">
                                                        <Border Classes="reading-box"
                                                                Margin="0,0,8,8"
                                                                MinWidth="170">
                                                            <StackPanel Spacing="4">
                                                                <StackPanel Orientation="Horizontal" Spacing="6">
                                                                    <TextBlock Text="{Binding Name}"
                                                                               FontSize="{StaticResource FontSizeMeta}"
                                                                               FontWeight="SemiBold"
                                                                               Foreground="{StaticResource BrushTextMuted}" />
                                                                    <TextBlock Text="{Binding Description}"
                                                                               FontSize="{StaticResource FontSizeLabelSmall}"
                                                                               Opacity="0.45"
                                                                               Foreground="{StaticResource BrushTextPrimary}"
                                                                               VerticalAlignment="Center" />
                                                                </StackPanel>
                                                                <TextBlock Text="{Binding DisplayValue}"
                                                                           FontSize="20"
                                                                           FontWeight="Medium"
                                                                           Foreground="{StaticResource BrushTextPrimary}" />
                                                            </StackPanel>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>

                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- Tab 2: Energies / Demands -->
            <TabItem>
                <TabItem.Header>
                    <TextBlock Text="{Binding [TabEnergiesDemands], Source={x:Static svc:LocalizationService.Instance}}" />
                </TabItem.Header>
                <TextBlock Text="{Binding [TabComingSoon], Source={x:Static svc:LocalizationService.Instance}}"
                           Opacity="0.5"
                           Margin="0,12" />
            </TabItem>

            <!-- Tab 3: Inputs & Outputs -->
            <TabItem>
                <TabItem.Header>
                    <TextBlock Text="{Binding [TabInputsOutputs], Source={x:Static svc:LocalizationService.Instance}}" />
                </TabItem.Header>
                <TextBlock Text="{Binding [TabComingSoon], Source={x:Static svc:LocalizationService.Instance}}"
                           Opacity="0.5"
                           Margin="0,12" />
            </TabItem>

            <!-- Tab 4: Hourmeter -->
            <TabItem>
                <TabItem.Header>
                    <TextBlock Text="{Binding [TabHourmeter], Source={x:Static svc:LocalizationService.Instance}}" />
                </TabItem.Header>
                <TextBlock Text="{Binding [TabComingSoon], Source={x:Static svc:LocalizationService.Instance}}"
                           Opacity="0.5"
                           Margin="0,12" />
            </TabItem>

            <!-- Tab 5: Status -->
            <TabItem>
                <TabItem.Header>
                    <TextBlock Text="{Binding [TabStatus], Source={x:Static svc:LocalizationService.Instance}}" />
                </TabItem.Header>
                <TextBlock Text="{Binding [TabComingSoon], Source={x:Static svc:LocalizationService.Instance}}"
                           Opacity="0.5"
                           Margin="0,12" />
            </TabItem>

        </TabControl>

    </DockPanel>
</UserControl>
