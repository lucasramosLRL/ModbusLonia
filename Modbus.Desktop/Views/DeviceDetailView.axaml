<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Modbus.Desktop.ViewModels"
             x:Class="Modbus.Desktop.Views.DeviceDetailView"
             x:DataType="vm:DeviceDetailViewModel">

    <DockPanel Margin="28,20">

        <!-- Header -->
        <Grid DockPanel.Dock="Top" ColumnDefinitions="Auto,*,Auto" Margin="0,0,0,20">
            <Button Content="← Back"
                    Command="{Binding GoBackCommand}"
                    Padding="12,8"
                    VerticalAlignment="Center" />
            <StackPanel Grid.Column="1" Margin="20,0" VerticalAlignment="Center">
                <TextBlock Text="{Binding Device.Name}"
                           FontSize="24"
                           FontWeight="SemiBold" />
                <TextBlock Text="{Binding Device.StatusText}"
                           FontSize="13"
                           Opacity="0.65" />
            </StackPanel>
            <Button Grid.Column="2"
                    Content="Refresh"
                    Command="{Binding RefreshCommand}"
                    Padding="16,8"
                    VerticalAlignment="Center" />
        </Grid>

        <!-- Loading bar -->
        <ProgressBar DockPanel.Dock="Top"
                     IsIndeterminate="True"
                     IsVisible="{Binding IsLoading}"
                     Height="3"
                     Margin="0,0,0,12" />

        <!-- Device info card -->
        <Border DockPanel.Dock="Top"
                Padding="16"
                Margin="0,0,0,16"
                CornerRadius="8"
                BorderThickness="1"
                BorderBrush="#1A1A2E"
                Background="#1A1A2E">
            <Grid ColumnDefinitions="*,*,*,*" >
                <StackPanel Grid.Column="0" Spacing="4">
                    <TextBlock Text="Transport" FontSize="11" Opacity="0.55" Foreground="#FFFFFF" />
                    <TextBlock Text="{Binding Device.TransportType}" FontWeight="Medium" Foreground="#FFFFFF" />
                </StackPanel>
                <StackPanel Grid.Column="1" Spacing="4">
                    <TextBlock Text="Address" FontSize="11" Opacity="0.55" Foreground="#FFFFFF" />
                    <TextBlock Text="{Binding Device.ConnectionAddress}" FontWeight="Medium" Foreground="#FFFFFF" />
                </StackPanel>
                <StackPanel Grid.Column="2" Spacing="4">
                    <TextBlock Text="Address" FontSize="11" Opacity="0.55" Foreground="#FFFFFF" />
                    <TextBlock Text="{Binding Device.SlaveId}" FontWeight="Medium" Foreground="#FFFFFF" />
                </StackPanel>
                <StackPanel Grid.Column="3" Spacing="4">
                    <TextBlock Text="Model" FontSize="11" Opacity="0.55" Foreground="#FFFFFF" />
                    <TextBlock Text="{Binding Device.ModelName, FallbackValue='Unknown'}" FontWeight="Medium" Foreground="#FFFFFF" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- Register section header -->
        <TextBlock DockPanel.Dock="Top"
                   Text="Register Values"
                   FontSize="16"
                   FontWeight="SemiBold"
                   Margin="0,0,0,8" />

        <!-- Empty state -->
        <TextBlock DockPanel.Dock="Top"
                   Text="No register values yet. Values will appear after the first successful poll."
                   IsVisible="{Binding !RegisterValues.Count}"
                   Opacity="0.5"
                   Margin="0,12" />

        <!-- Register values DataGrid -->
        <DataGrid ItemsSource="{Binding RegisterValues}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  GridLinesVisibility="Horizontal"
                  CanUserResizeColumns="True">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Name"
                                    Binding="{Binding Name}"
                                    Width="*" />
                <DataGridTextColumn Header="Address"
                                    Binding="{Binding Address}"
                                    Width="80" />
                <DataGridTextColumn Header="Type"
                                    Binding="{Binding RegisterType}"
                                    Width="80" />
                <DataGridTextColumn Header="Value"
                                    Binding="{Binding DisplayValue}"
                                    Width="140" />
                <DataGridTextColumn Header="Last Updated"
                                    Binding="{Binding Timestamp, StringFormat='{}{0:HH:mm:ss}'}"
                                    Width="110" />
            </DataGrid.Columns>
        </DataGrid>

    </DockPanel>
</UserControl>
