<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Modbus.Desktop.ViewModels"
             xmlns:svc="using:Modbus.Desktop.Services"
             x:Class="Modbus.Desktop.Views.DeviceDetailView"
             x:DataType="vm:DeviceDetailViewModel">

    <DockPanel Margin="28,20">

        <!-- Header -->
        <Grid DockPanel.Dock="Top" ColumnDefinitions="Auto,*,Auto" Margin="0,0,0,20">
            <Button Content="{Binding [Back], Source={x:Static svc:LocalizationService.Instance}}"
                    Command="{Binding GoBackCommand}"
                    Padding="12,8"
                    VerticalAlignment="Center" />
            <StackPanel Grid.Column="1" Margin="20,0" VerticalAlignment="Center">
                <TextBlock Text="{Binding Device.Name}"
                           FontSize="24"
                           FontWeight="SemiBold" />
                <TextBlock Text="{Binding Device.StatusText}"
                           FontSize="13"
                           Opacity="0.65" />
            </StackPanel>
            <Button Grid.Column="2"
                    Content="{Binding [Refresh], Source={x:Static svc:LocalizationService.Instance}}"
                    Command="{Binding RefreshCommand}"
                    Padding="16,8"
                    VerticalAlignment="Center" />
        </Grid>

        <!-- Loading bar -->
        <ProgressBar DockPanel.Dock="Top"
                     IsIndeterminate="True"
                     IsVisible="{Binding IsLoading}"
                     Height="3"
                     Margin="0,0,0,12" />

        <!-- Device info card -->
        <Border DockPanel.Dock="Top"
                Padding="16"
                Margin="0,0,0,16"
                CornerRadius="8"
                BorderThickness="1"
                BorderBrush="#1A1A2E"
                Background="#1A1A2E">
            <Grid ColumnDefinitions="*,*,*,*">
                <StackPanel Grid.Column="0" Spacing="4">
                    <TextBlock Text="{Binding [Transport], Source={x:Static svc:LocalizationService.Instance}}"
                               FontSize="11" Opacity="0.55" Foreground="#FFFFFF" />
                    <TextBlock Text="{Binding Device.TransportType}" FontWeight="Medium" Foreground="#FFFFFF" />
                </StackPanel>
                <StackPanel Grid.Column="1" Spacing="4">
                    <TextBlock Text="{Binding [Connection], Source={x:Static svc:LocalizationService.Instance}}"
                               FontSize="11" Opacity="0.55" Foreground="#FFFFFF" />
                    <TextBlock Text="{Binding Device.ConnectionAddress}" FontWeight="Medium" Foreground="#FFFFFF" />
                </StackPanel>
                <StackPanel Grid.Column="2" Spacing="4">
                    <TextBlock Text="{Binding [SlaveAddress], Source={x:Static svc:LocalizationService.Instance}}"
                               FontSize="11" Opacity="0.55" Foreground="#FFFFFF" />
                    <TextBlock Text="{Binding Device.SlaveId}" FontWeight="Medium" Foreground="#FFFFFF" />
                </StackPanel>
                <StackPanel Grid.Column="3" Spacing="4">
                    <TextBlock Text="{Binding [Model], Source={x:Static svc:LocalizationService.Instance}}"
                               FontSize="11" Opacity="0.55" Foreground="#FFFFFF" />
                    <TextBlock Text="{Binding Device.ModelDisplayName}" FontWeight="Medium" Foreground="#FFFFFF" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- Register section header -->
        <TextBlock DockPanel.Dock="Top"
                   Text="{Binding [RegisterValues], Source={x:Static svc:LocalizationService.Instance}}"
                   FontSize="16"
                   FontWeight="SemiBold"
                   Margin="0,0,0,8" />

        <!-- Empty state -->
        <TextBlock DockPanel.Dock="Top"
                   Text="{Binding [NoRegisterValues], Source={x:Static svc:LocalizationService.Instance}}"
                   IsVisible="{Binding !RegisterValues.Count}"
                   Opacity="0.5"
                   Margin="0,12" />

        <!-- Register values DataGrid -->
        <DataGrid ItemsSource="{Binding RegisterValues}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  GridLinesVisibility="Horizontal"
                  CanUserResizeColumns="True">
            <DataGrid.Columns>
                <DataGridTextColumn Binding="{Binding Name}" Width="*">
                    <DataGridTextColumn.Header>
                        <TextBlock Text="{Binding [ColName], Source={x:Static svc:LocalizationService.Instance}}" />
                    </DataGridTextColumn.Header>
                </DataGridTextColumn>
                <DataGridTextColumn Binding="{Binding Address}" Width="80">
                    <DataGridTextColumn.Header>
                        <TextBlock Text="{Binding [ColAddress], Source={x:Static svc:LocalizationService.Instance}}" />
                    </DataGridTextColumn.Header>
                </DataGridTextColumn>
                <DataGridTextColumn Binding="{Binding RegisterType}" Width="80">
                    <DataGridTextColumn.Header>
                        <TextBlock Text="{Binding [ColType], Source={x:Static svc:LocalizationService.Instance}}" />
                    </DataGridTextColumn.Header>
                </DataGridTextColumn>
                <DataGridTextColumn Binding="{Binding DisplayValue}" Width="140">
                    <DataGridTextColumn.Header>
                        <TextBlock Text="{Binding [ColValue], Source={x:Static svc:LocalizationService.Instance}}" />
                    </DataGridTextColumn.Header>
                </DataGridTextColumn>
                <DataGridTextColumn Binding="{Binding Timestamp, StringFormat='{}{0:HH:mm:ss}'}" Width="110">
                    <DataGridTextColumn.Header>
                        <TextBlock Text="{Binding [ColLastUpdated], Source={x:Static svc:LocalizationService.Instance}}" />
                    </DataGridTextColumn.Header>
                </DataGridTextColumn>
            </DataGrid.Columns>
        </DataGrid>

    </DockPanel>
</UserControl>
