<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Modbus.Desktop.ViewModels"
             xmlns:svc="using:Modbus.Desktop.Services"
             x:Class="Modbus.Desktop.Views.DeviceListView"
             x:DataType="vm:DeviceListViewModel">

    <DockPanel Margin="{StaticResource MarginView}">

        <!-- Header -->
        <Grid DockPanel.Dock="Top" ColumnDefinitions="*,Auto,Auto" Margin="0,0,0,16">
            <TextBlock Text="{Binding [Devices], Source={x:Static svc:LocalizationService.Instance}}"
                       Classes="main-title"
                       VerticalAlignment="Center" />
            <Button Grid.Column="1"
                    Content="{Binding [AddDevice], Source={x:Static svc:LocalizationService.Instance}}"
                    Command="{Binding OpenAddDeviceCommand}"
                    Padding="{StaticResource PaddingButton}"
                    Margin="0,0,8,0" />
            <Button Grid.Column="2"
                    Content="{Binding [Refresh], Source={x:Static svc:LocalizationService.Instance}}"
                    Command="{Binding LoadDevicesCommand}"
                    Padding="{StaticResource PaddingButton}" />
        </Grid>

        <!-- Loading bar -->
        <ProgressBar DockPanel.Dock="Top"
                     IsIndeterminate="True"
                     IsVisible="{Binding IsLoading}"
                     Height="3"
                     Margin="0,0,0,12" />

        <!-- Empty state -->
        <TextBlock DockPanel.Dock="Top"
                   Text="{Binding [NoDevicesFound], Source={x:Static svc:LocalizationService.Instance}}"
                   IsVisible="{Binding !Devices.Count}"
                   Opacity="0.5"
                   HorizontalAlignment="Center"
                   Margin="0,40" />

        <!-- Device list -->
        <ScrollViewer>
            <ItemsControl x:Name="DeviceList" ItemsSource="{Binding Devices}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type vm:DeviceItemViewModel}">
                        <Border Classes="card" Margin="0,0,0,8">
                            <Grid ColumnDefinitions="*,Auto">

                                <!-- Left: device info -->
                                <StackPanel Spacing="4">
                                    <TextBlock Text="{Binding Name}"
                                               FontSize="{StaticResource FontSizeCardTitle}"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource BrushTextPrimary}" />
                                    <TextBlock Text="{Binding ConnectionAddress}"
                                               FontSize="{StaticResource FontSizeSectionTitle}"
                                               Opacity="0.65"
                                               Foreground="{StaticResource BrushTextPrimary}" />
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <TextBlock Text="{Binding TransportType}"
                                                   FontSize="{StaticResource FontSizeMeta}"
                                                   Opacity="0.55"
                                                   Foreground="{StaticResource BrushTextPrimary}" />
                                        <TextBlock Text="·" Opacity="0.35" Foreground="{StaticResource BrushTextPrimary}" />
                                        <TextBlock Text="{Binding ModelDisplayName}"
                                                   FontSize="{StaticResource FontSizeMeta}"
                                                   Opacity="0.55"
                                                   Foreground="{StaticResource BrushTextPrimary}" />
                                        <TextBlock Text="·" Opacity="0.35" Foreground="{StaticResource BrushTextPrimary}" />
                                        <TextBlock Text="{Binding SlaveIdText}"
                                                   FontSize="{StaticResource FontSizeMeta}"
                                                   Opacity="0.55"
                                                   Foreground="{StaticResource BrushTextPrimary}" />
                                    </StackPanel>
                                </StackPanel>

                                <!-- Right: status + open -->
                                <StackPanel Grid.Column="1"
                                            VerticalAlignment="Center"
                                            HorizontalAlignment="Right"
                                            Spacing="8">
                                    <TextBlock Text="{Binding StatusText}"
                                               HorizontalAlignment="Right"
                                               FontSize="{StaticResource FontSizeSectionTitle}"
                                               FontWeight="Medium"
                                               Foreground="{StaticResource BrushTextPrimary}" />
                                    <TextBlock Text="{Binding LastSeenText}"
                                               FontSize="{StaticResource FontSizeLabelSmall}"
                                               Opacity="0.6"
                                               HorizontalAlignment="Right"
                                               Foreground="{StaticResource BrushTextPrimary}" />
                                    <StackPanel Orientation="Horizontal"
                                              HorizontalAlignment="Right"
                                              Spacing="6">
                                        <Button Content="{Binding [Open], Source={x:Static svc:LocalizationService.Instance}}"
                                                Padding="12,6"
                                                Command="{Binding #DeviceList.DataContext.OpenDeviceDetailCommand}"
                                                CommandParameter="{Binding}" />
                                        <Button Content="{Binding [Delete], Source={x:Static svc:LocalizationService.Instance}}"
                                                Padding="12,6"
                                                Click="OnDeleteClick"
                                                Tag="{Binding}" />
                                    </StackPanel>
                                </StackPanel>

                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

    </DockPanel>
</UserControl>
