<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Modbus.Desktop.ViewModels"
             xmlns:svc="using:Modbus.Desktop.Services"
             x:Class="Modbus.Desktop.Views.DeviceHubView"
             x:DataType="vm:DeviceHubViewModel">

    <DockPanel Margin="{StaticResource MarginView}">

        <!-- Header -->
        <Grid DockPanel.Dock="Top" ColumnDefinitions="Auto,*" Margin="0,0,0,24">
            <Button Content="{Binding [Back], Source={x:Static svc:LocalizationService.Instance}}"
                    Command="{Binding GoBackCommand}"
                    Padding="{StaticResource PaddingButtonSmall}"
                    VerticalAlignment="Center" />
            <StackPanel Grid.Column="1" Margin="20,0" VerticalAlignment="Center" Spacing="2">
                <TextBlock Text="{Binding Device.Name}"
                           Classes="page-title" />
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <TextBlock Text="{Binding Device.ModelDisplayName}"
                               FontSize="{StaticResource FontSizeMeta}"
                               Opacity="0.55" />
                    <TextBlock Text="·" Opacity="0.35" />
                    <TextBlock Text="{Binding Device.ConnectionAddress}"
                               FontSize="{StaticResource FontSizeMeta}"
                               Opacity="0.55" />
                    <TextBlock Text="·" Opacity="0.35" />
                    <TextBlock Text="{Binding Device.StatusText}"
                               FontSize="{StaticResource FontSizeMeta}"
                               FontWeight="Medium"
                               Opacity="0.8" />
                </StackPanel>
            </StackPanel>
        </Grid>

        <!-- Feature cards -->
        <ScrollViewer>
            <WrapPanel Orientation="Horizontal">

                <!-- Leitura em Tempo Real -->
                <Border Classes="card-hub"
                        Width="260" Height="160"
                        Margin="0,0,16,16">
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Top"
                                   Text="{Binding [HubReadings], Source={x:Static svc:LocalizationService.Instance}}"
                                   Classes="section-title"
                                   FontSize="{StaticResource FontSizeCardTitle}" />
                        <TextBlock DockPanel.Dock="Top"
                                   Text="{Binding [HubReadingsDesc], Source={x:Static svc:LocalizationService.Instance}}"
                                   FontSize="{StaticResource FontSizeMeta}"
                                   Opacity="0.6"
                                   TextWrapping="Wrap"
                                   Margin="0,6,0,0"
                                   Foreground="{StaticResource BrushTextPrimary}" />
                        <Button DockPanel.Dock="Bottom"
                                Content="{Binding [Open], Source={x:Static svc:LocalizationService.Instance}}"
                                Command="{Binding OpenReadingsCommand}"
                                Padding="{StaticResource PaddingButton}"
                                HorizontalAlignment="Left" />
                    </DockPanel>
                </Border>

                <!-- Memória de Massa -->
                <Border Classes="card-hub"
                        Width="260" Height="160"
                        Margin="0,0,16,16"
                        Opacity="0.45">
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Top"
                                   Text="{Binding [HubMassMemory], Source={x:Static svc:LocalizationService.Instance}}"
                                   Classes="section-title"
                                   FontSize="{StaticResource FontSizeCardTitle}" />
                        <TextBlock DockPanel.Dock="Top"
                                   Text="{Binding [HubMassMemoryDesc], Source={x:Static svc:LocalizationService.Instance}}"
                                   FontSize="{StaticResource FontSizeMeta}"
                                   Opacity="0.6"
                                   TextWrapping="Wrap"
                                   Margin="0,6,0,0"
                                   Foreground="{StaticResource BrushTextPrimary}" />
                        <Button DockPanel.Dock="Bottom"
                                Content="{Binding [Open], Source={x:Static svc:LocalizationService.Instance}}"
                                IsEnabled="False"
                                Padding="{StaticResource PaddingButton}"
                                HorizontalAlignment="Left" />
                    </DockPanel>
                </Border>

                <!-- Configurar -->
                <Border Classes="card-hub"
                        Width="260" Height="160"
                        Margin="0,0,16,16"
                        Opacity="0.45">
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Top"
                                   Text="{Binding [HubConfigure], Source={x:Static svc:LocalizationService.Instance}}"
                                   Classes="section-title"
                                   FontSize="{StaticResource FontSizeCardTitle}" />
                        <TextBlock DockPanel.Dock="Top"
                                   Text="{Binding [HubConfigureDesc], Source={x:Static svc:LocalizationService.Instance}}"
                                   FontSize="{StaticResource FontSizeMeta}"
                                   Opacity="0.6"
                                   TextWrapping="Wrap"
                                   Margin="0,6,0,0"
                                   Foreground="{StaticResource BrushTextPrimary}" />
                        <Button DockPanel.Dock="Bottom"
                                Content="{Binding [Open], Source={x:Static svc:LocalizationService.Instance}}"
                                IsEnabled="False"
                                Padding="{StaticResource PaddingButton}"
                                HorizontalAlignment="Left" />
                    </DockPanel>
                </Border>

            </WrapPanel>
        </ScrollViewer>

    </DockPanel>
</UserControl>
