<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Modbus.Desktop.ViewModels"
        x:Class="Modbus.Desktop.Views.MainWindow"
        x:DataType="vm:MainViewModel"
        Title="ModbusApp"
        Width="1100" Height="700"
        MinWidth="800" MinHeight="500">
      
    <Grid ColumnDefinitions="220,*">

        <!-- Sidebar -->
        <Border Grid.Column="0" Background="#1A1A2E">
            <DockPanel>

                <!-- App title -->
                <Border DockPanel.Dock="Top" Padding="20,24,20,16">
                    <StackPanel Spacing="2">
                        <TextBlock Text="ModbusApp"
                                   Foreground="White"
                                   FontSize="18"
                                   FontWeight="SemiBold" />
                        <TextBlock Text="Device Monitor"
                                   Foreground="#7070A0"
                                   FontSize="11" />
                    </StackPanel>
                </Border>

                <!-- Separator -->
                <Border DockPanel.Dock="Top" Height="1" Background="#2A2A4A" Margin="16,0" />

                <!-- Nav items -->
                <ListBox Background="Transparent"
                         Margin="8,8,8,0"
                         ItemsSource="{Binding NavItems}"
                         SelectedItem="{Binding SelectedNavItem}">
                    <ListBox.Styles>
                        <Style Selector="ListBoxItem">
                            <Setter Property="Padding" Value="12,10" />
                            <Setter Property="CornerRadius" Value="6" />
                            <Setter Property="Foreground" Value="#9090B0" />
                        </Style>
                        <Style Selector="ListBoxItem:pointerover /template/ ContentPresenter">
                            <Setter Property="Background" Value="#252540" />
                        </Style>
                        <Style Selector="ListBoxItem:selected /template/ ContentPresenter">
                            <Setter Property="Background" Value="#2E2E5A" />
                        </Style>
                        <Style Selector="ListBoxItem:selected">
                            <Setter Property="Foreground" Value="White" />
                        </Style>
                    </ListBox.Styles>
                    <ListBox.ItemTemplate>
                        <DataTemplate DataType="{x:Type vm:NavItem}">
                            <StackPanel Orientation="Horizontal" Spacing="12">
                                <TextBlock Text="{Binding Icon}"
                                           FontSize="15"
                                           VerticalAlignment="Center" />
                                <TextBlock Text="{Binding Title}"
                                           FontSize="14"
                                           VerticalAlignment="Center" />
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

            </DockPanel>
        </Border>

        <!-- Main content -->
        <ContentControl Grid.Column="1" Content="{Binding CurrentPage}" />

    </Grid>
</Window>
