<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Styles.Resources>

        <!-- ── Colors ────────────────────────────────────────────────────── -->
        <Color x:Key="ColorBgDark">#1A1A2E</Color>
        <Color x:Key="ColorBgElevated">#252540</Color>
        <Color x:Key="ColorBgSelected">#2E2E5A</Color>
        <Color x:Key="ColorBgSeparator">#2A2A4A</Color>
        <Color x:Key="ColorTextPrimary">#FFFFFF</Color>
        <Color x:Key="ColorTextMuted">#7070A0</Color>
        <Color x:Key="ColorTextSubtle">#9090B0</Color>
        <Color x:Key="ColorErrorRed">#D32F2F</Color>
        <Color x:Key="ColorErrorLight">#E57373</Color>
        <Color x:Key="ColorWarningOrange">#FFB300</Color>
        <Color x:Key="ColorSuccessGreen">#388E3C</Color>

        <!-- ── Brushes ───────────────────────────────────────────────────── -->
        <SolidColorBrush x:Key="BrushBgDark"      Color="{StaticResource ColorBgDark}"/>
        <SolidColorBrush x:Key="BrushBgElevated"  Color="{StaticResource ColorBgElevated}"/>
        <SolidColorBrush x:Key="BrushBgSelected"  Color="{StaticResource ColorBgSelected}"/>
        <SolidColorBrush x:Key="BrushBgSeparator" Color="{StaticResource ColorBgSeparator}"/>
        <SolidColorBrush x:Key="BrushTextPrimary" Color="{StaticResource ColorTextPrimary}"/>
        <SolidColorBrush x:Key="BrushTextMuted"   Color="{StaticResource ColorTextMuted}"/>
        <SolidColorBrush x:Key="BrushTextSubtle"  Color="{StaticResource ColorTextSubtle}"/>
        <SolidColorBrush x:Key="BrushErrorRed"    Color="{StaticResource ColorErrorRed}"/>
        <SolidColorBrush x:Key="BrushErrorLight"  Color="{StaticResource ColorErrorLight}"/>
        <SolidColorBrush x:Key="BrushWarningOrange" Color="{StaticResource ColorWarningOrange}"/>
        <SolidColorBrush x:Key="BrushSuccessGreen"  Color="{StaticResource ColorSuccessGreen}"/>

        <!-- ── Corner Radii ──────────────────────────────────────────────── -->
        <CornerRadius x:Key="RadiusCard">8</CornerRadius>
        <CornerRadius x:Key="RadiusCardSmall">6</CornerRadius>
        <CornerRadius x:Key="RadiusCardLarge">10</CornerRadius>

        <!-- ── Thickness / Padding ───────────────────────────────────────── -->
        <Thickness x:Key="PaddingCard">16</Thickness>
        <Thickness x:Key="PaddingCardHub">20</Thickness>
        <Thickness x:Key="PaddingButton">16,8</Thickness>
        <Thickness x:Key="PaddingButtonSmall">12,8</Thickness>
        <Thickness x:Key="MarginView">28,20</Thickness>

        <!-- ── Font Sizes ────────────────────────────────────────────────── -->
        <x:Double x:Key="FontSizeMainTitle">26</x:Double>
        <x:Double x:Key="FontSizePageTitle">24</x:Double>
        <x:Double x:Key="FontSizeAppTitle">18</x:Double>
        <x:Double x:Key="FontSizeCardTitle">16</x:Double>
        <x:Double x:Key="FontSizeGroupHeader">15</x:Double>
        <x:Double x:Key="FontSizeSectionTitle">13</x:Double>
        <x:Double x:Key="FontSizeMeta">12</x:Double>
        <x:Double x:Key="FontSizeLabelSmall">11</x:Double>

    </Styles.Resources>

    <!-- ── Component Styles ──────────────────────────────────────────────── -->

    <!-- Standard card: dark background, rounded corners, standard padding -->
    <Style Selector="Border.card">
        <Setter Property="Background"       Value="{StaticResource BrushBgDark}"/>
        <Setter Property="BorderBrush"      Value="{StaticResource BrushBgDark}"/>
        <Setter Property="BorderThickness"  Value="1"/>
        <Setter Property="CornerRadius"     Value="{StaticResource RadiusCard}"/>
        <Setter Property="Padding"          Value="{StaticResource PaddingCard}"/>
    </Style>

    <!-- Hub feature card: larger padding and corner radius -->
    <Style Selector="Border.card-hub">
        <Setter Property="Background"       Value="{StaticResource BrushBgDark}"/>
        <Setter Property="BorderBrush"      Value="{StaticResource BrushBgDark}"/>
        <Setter Property="BorderThickness"  Value="1"/>
        <Setter Property="CornerRadius"     Value="{StaticResource RadiusCardLarge}"/>
        <Setter Property="Padding"          Value="{StaticResource PaddingCardHub}"/>
    </Style>

    <!-- Reading group container: elevated background, card radius -->
    <Style Selector="Border.reading-group">
        <Setter Property="Background"   Value="{StaticResource BrushBgElevated}"/>
        <Setter Property="CornerRadius" Value="{StaticResource RadiusCard}"/>
        <Setter Property="Padding"      Value="{StaticResource PaddingCard}"/>
    </Style>

    <!-- Individual electrical reading value box -->
    <Style Selector="Border.reading-box">
        <Setter Property="Background"   Value="{StaticResource BrushBgDark}"/>
        <Setter Property="CornerRadius" Value="{StaticResource RadiusCardSmall}"/>
        <Setter Property="Padding"      Value="14,10"/>
    </Style>

    <!-- Page title: 24pt SemiBold (DeviceDetail, DeviceHub, AddDevice headers) -->
    <Style Selector="TextBlock.page-title">
        <Setter Property="FontSize"   Value="{StaticResource FontSizePageTitle}"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
    </Style>

    <!-- Main title: 26pt SemiBold (DeviceList, Settings headers) -->
    <Style Selector="TextBlock.main-title">
        <Setter Property="FontSize"   Value="{StaticResource FontSizeMainTitle}"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
    </Style>

    <!-- Section title inside a card: 13pt SemiBold white -->
    <Style Selector="TextBlock.section-title">
        <Setter Property="FontSize"   Value="{StaticResource FontSizeSectionTitle}"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{StaticResource BrushTextPrimary}"/>
    </Style>

    <!-- Small label above a form field: 11pt dimmed white -->
    <Style Selector="TextBlock.label-small">
        <Setter Property="FontSize"   Value="{StaticResource FontSizeLabelSmall}"/>
        <Setter Property="Opacity"    Value="0.55"/>
        <Setter Property="Foreground" Value="{StaticResource BrushTextPrimary}"/>
    </Style>

</Styles>
